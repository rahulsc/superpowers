#!/usr/bin/env bash
# forge-state — unified state storage CLI for Forge
# Usage:
#   forge-state init [--project-dir DIR]
#   forge-state get <key> [--project-dir DIR]
#   forge-state set <key> <value> [--project-dir DIR]
#   forge-state backend [--project-dir DIR]

set -euo pipefail

# --- Locate library directory ---
FORGE_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FORGE_LIB_DIR="$FORGE_BIN_DIR/lib"

# --- Argument parsing ---
SUBCOMMAND=""
ARGS=()
PROJECT_DIR=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --project-dir)
            shift
            PROJECT_DIR="$1"
            shift
            ;;
        --project-dir=*)
            PROJECT_DIR="${1#--project-dir=}"
            shift
            ;;
        -*)
            # Unknown flag — pass through (ignore gracefully)
            shift
            ;;
        *)
            if [ -z "$SUBCOMMAND" ]; then
                SUBCOMMAND="$1"
            else
                ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

# --- Resolve project directory ---
if [ -z "$PROJECT_DIR" ]; then
    # Use env var or current directory
    PROJECT_DIR="${FORGE_PROJECT_DIR:-$(pwd)}"
fi

# --- Resolve backend ---
_detect_backend() {
    local project_dir="$1"

    # Priority 1: explicit FORGE_BACKEND env var
    if [ -n "${FORGE_BACKEND:-}" ]; then
        printf '%s' "$FORGE_BACKEND"
        return
    fi

    # Priority 2: .forge/project.yaml storage field
    local project_yaml="$project_dir/.forge/project.yaml"
    if [ -f "$project_yaml" ]; then
        local storage_val
        storage_val=$(grep -m1 '^storage:' "$project_yaml" 2>/dev/null | sed 's/^storage:[[:space:]]*//' | tr -d '"'"'" | tr -d '[:space:]')
        if [ -n "$storage_val" ]; then
            printf '%s' "$storage_val"
            return
        fi
    fi

    # Priority 3: sqlite3 on PATH
    if command -v sqlite3 &>/dev/null; then
        printf 'sqlite'
        return
    fi

    # Priority 4: fallback to JSON
    printf 'json'
}

BACKEND=$(_detect_backend "$PROJECT_DIR")

# --- Load backend library ---
case "$BACKEND" in
    sqlite)
        # shellcheck source=lib/backend-sqlite.sh
        source "$FORGE_LIB_DIR/backend-sqlite.sh"
        ;;
    json|*)
        BACKEND=json
        # shellcheck source=lib/backend-json.sh
        source "$FORGE_LIB_DIR/backend-json.sh"
        ;;
esac

# --- Dispatch ---
case "$SUBCOMMAND" in
    init)
        if [ "$BACKEND" = "sqlite" ]; then
            sqlite_init "$PROJECT_DIR"
        else
            json_init "$PROJECT_DIR"
        fi
        ;;

    get)
        if [ "${#ARGS[@]}" -lt 1 ]; then
            printf 'error: forge-state get requires a key\n' >&2
            exit 1
        fi
        KEY="${ARGS[0]}"
        if [ "$BACKEND" = "sqlite" ]; then
            sqlite_get "$PROJECT_DIR" "$KEY"
        else
            json_get "$PROJECT_DIR" "$KEY"
        fi
        ;;

    set)
        if [ "${#ARGS[@]}" -lt 2 ]; then
            printf 'error: forge-state set requires a key and value\n' >&2
            exit 1
        fi
        KEY="${ARGS[0]}"
        VALUE="${ARGS[1]}"
        if [ "$BACKEND" = "sqlite" ]; then
            sqlite_set "$PROJECT_DIR" "$KEY" "$VALUE"
        else
            json_set "$PROJECT_DIR" "$KEY" "$VALUE"
        fi
        ;;

    backend)
        printf '%s\n' "$BACKEND"
        ;;

    "")
        printf 'Usage: forge-state <init|get|set|backend> [options]\n' >&2
        exit 1
        ;;

    *)
        printf 'error: unknown subcommand: %s\n' "$SUBCOMMAND" >&2
        exit 1
        ;;
esac
